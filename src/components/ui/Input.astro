---
interface Props {
  name:         string;
  label:        string;
  type?:        'text' | 'email' | 'tel' | 'password' | 'number';
  placeholder?: string;
  required?:    boolean;
  value?:       string;
}

const { name, label, type = 'text', placeholder, required = false, value } = Astro.props;
---
<div class="flex flex-col gap-1.5">
  <label for={name} class="font-medium text-dark text-sm">
    {label}
    {required && <span class="text-accent ml-1" aria-hidden="true">*</span>}
  </label>
  <input
    id={name}
    name={name}
    type={type}
    placeholder={placeholder}
    required={required}
    value={value}
    class="border border-light rounded-xl px-4 py-3 text-dark focus:outline-none focus:ring-2 focus:ring-primary bg-background"
  />
</div>
