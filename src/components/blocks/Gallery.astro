---
import type { GalleryImage } from '@/types/content';

interface Props {
  images:  GalleryImage[];
  title?:  string;
  columns?: 2 | 3 | 4;
}

const { images, title, columns = 3 } = Astro.props;

const gridCols: Record<number, string> = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
};
---
<section class="py-20 bg-background" id="galeria">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    {title && (
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-dark text-center mb-14">
        {title}
      </h2>
    )}
    <div class={`grid grid-cols-1 ${gridCols[columns]} gap-4`}>
      {images.map(img => (
        <figure class="overflow-hidden rounded-xl aspect-square">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
        </figure>
      ))}
    </div>
  </div>
</section>
