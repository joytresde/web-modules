---
interface Props {
  src:    string;
  label?: string;
  title?: string;
}

const { src, label, title = 'Nuestra ubicación' } = Astro.props;
---
<section class="py-20 bg-background" id="ubicacion">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    {title && (
      <h2 class="font-heading text-3xl font-bold text-dark text-center mb-10">{title}</h2>
    )}
    {label && (
      <p class="text-dark/60 text-center mb-6">{label}</p>
    )}
    <div class="rounded-2xl overflow-hidden shadow-lg aspect-video w-full">
      <iframe
        src={src}
        title={label ?? title}
        width="100%"
        height="100%"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="border-0"
      ></iframe>
    </div>
  </div>
</section>
