---
interface Props {
  phone:    string;
  message?: string;
}

const { phone, message = '' } = Astro.props;

const cleanPhone = phone.replace(/\D/g, '');
const waHref     = message
  ? `https://wa.me/${cleanPhone}?text=${encodeURIComponent(message)}`
  : `https://wa.me/${cleanPhone}`;
---
<a
  href={waHref}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escríbenos por WhatsApp"
  class="fixed bottom-6 right-6 z-50 flex items-center gap-2 bg-[#25D366] text-white px-4 py-3 rounded-full shadow-xl font-semibold text-sm hover:opacity-90 transition-opacity"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="currentColor"
    class="w-5 h-5 shrink-0"
    aria-hidden="true"
  >
