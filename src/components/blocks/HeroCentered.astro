---
import type { CTA } from '@/types/content';

interface Props {
  title:       string;
  subtitle:    string;
  cta:         CTA;
  badge?:      string;
  bgImage?:    string;
}

const {
  title,
  subtitle,
  cta,
  badge,
  bgImage = 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1600&q=80',
} = Astro.props;
---
<section
  id="inicio"
  class="relative min-h-[620px] flex items-center justify-center overflow-hidden"
>
  <!-- Imagen de fondo -->
  <img
    src={bgImage}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />
  <!-- Overlay degradado -->
  <div class="absolute inset-0 bg-gradient-to-br from-dark/80 via-primary/60 to-dark/70"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-28">
    {badge && (
      <span class="inline-block bg-accent/90 text-background text-sm font-semibold px-4 py-1 rounded-full mb-6 tracking-wide">
        {badge}
      </span>
    )}
    <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold text-background leading-tight">
      {title}
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-background/80 max-w-2xl mx-auto">
      {subtitle}
    </p>
    <a
      href={cta.href}
      class="mt-10 inline-flex bg-accent text-background px-8 py-3 rounded-xl font-semibold text-lg hover:opacity-90 transition-opacity shadow-lg"
    >
      {cta.label}
    </a>
  </div>
</section>
