---
import CatalogLayout from '@/layouts/CatalogLayout.astro';

const components = [
  {
    category: 'Estructura y Navegación',
    color:    'bg-violet-500/10 border-violet-500/30 text-violet-300',
    dot:      'bg-violet-400',
    items: [
      { name: 'Navbar',        file: 'Navbar.astro',        icon: '🧭', desc: 'Barra de navegación sticky con menú hamburguesa para móvil y CTA opcional.' },
      { name: 'Footer',        file: 'Footer.astro',        icon: '📄', desc: 'Pie de página con links de navegación, redes sociales y texto legal.' },
      { name: 'WhatsAppFloat', file: 'WhatsAppFloat.astro', icon: '💬', desc: 'Botón flotante fijo (bottom-right) que abre WhatsApp con mensaje pre-llenado.' },
    ],
  },
  {
    category: 'Hero / Entrada',
    color:    'bg-sky-500/10 border-sky-500/30 text-sky-300',
    dot:      'bg-sky-400',
    items: [
      { name: 'HeroFull',     file: 'HeroFull.astro',     icon: '🖼️', desc: 'Hero con imagen de fondo full-screen vía <Image /> de Astro y overlay oscuro.' },
      { name: 'HeroCentered', file: 'HeroCentered.astro', icon: '🎯', desc: 'Hero centrado con imagen de fondo externa, degradado overlay y badge opcional.' },
    ],
  },
  {
    category: 'Contenido Principal',
    color:    'bg-emerald-500/10 border-emerald-500/30 text-emerald-300',
    dot:      'bg-emerald-400',
    items: [
      { name: 'About',        file: 'About.astro',        icon: '👥', desc: 'Sección "Nosotros" con texto descriptivo e imagen lateral. Prop reverse para alternar posición.' },
      { name: 'CardGrid',     file: 'CardGrid.astro',     icon: '🗂️', desc: 'Grid de tarjetas para servicios o productos. Soporta 2, 3 o 4 columnas con ícono.' },
      { name: 'Gallery',      file: 'Gallery.astro',      icon: '🖼️', desc: 'Galería de imágenes en grid con efecto zoom-in en hover. Columns 2, 3 o 4.' },
      { name: 'LogoBar',      file: 'LogoBar.astro',      icon: '🏢', desc: 'Franja de logos de clientes en grayscale con efecto de color al hacer hover.' },
      { name: 'ProcessSteps', file: 'ProcessSteps.astro', icon: '➡️', desc: 'Pasos numerados horizontales en desktop / verticales en móvil. Línea conectora en CSS puro.' },
    ],
  },
  {
    category: 'Conversión',
    color:    'bg-orange-500/10 border-orange-500/30 text-orange-300',
    dot:      'bg-orange-400',
    items: [
      { name: 'CTABanner',    file: 'CTABanner.astro',    icon: '📢', desc: 'Banner oscuro de interrupción con título grande y dos CTAs (primario + secundario).' },
      { name: 'PricingCards', file: 'PricingCards.astro', icon: '💰', desc: 'Tarjetas de precios con plan "featured" elevado, lista de features con ✓/✕ y tachado.' },
      { name: 'ContactForm',  file: 'ContactForm.astro',  icon: '📧', desc: 'Formulario flexible con soporte para text, email, tel, textarea y select. Netlify Forms.' },
    ],
  },
  {
    category: 'Social Proof',
    color:    'bg-yellow-500/10 border-yellow-500/30 text-yellow-300',
    dot:      'bg-yellow-400',
    items: [
      { name: 'Testimonials', file: 'Testimonials.astro', icon: '⭐', desc: 'Grid de testimonios con avatar, nombre, rol y texto en estilo blockquote.' },
      { name: 'StatsBar',     file: 'StatsBar.astro',     icon: '📊', desc: 'Barra de estadísticas sobre fondo primary con valor grande y etiqueta.' },
    ],
  },
  {
    category: 'Información',
    color:    'bg-rose-500/10 border-rose-500/30 text-rose-300',
    dot:      'bg-rose-400',
    items: [
      { name: 'FAQ',       file: 'FAQ.astro',       icon: '❓', desc: 'Acordeón de preguntas frecuentes con animación CSS pura usando <details> nativo.' },
      { name: 'MapEmbed',  file: 'MapEmbed.astro',  icon: '📍', desc: 'Embed de Google Maps o cualquier iframe responsivo con aspect-ratio 16/9.' },
    ],
  },
];

const demos = [
  {
    href:       '/demo/servicios',
    title:      'Servicios del Hogar',
    client:     'TécnicosPro',
    desc:       'Empresa de plomería, electricidad y aires acondicionados en Caracas.',
    color:      'from-blue-600 to-orange-500',
    components: ['Navbar', 'HeroCentered', 'CardGrid', 'ProcessSteps', 'StatsBar', 'About', 'Testimonials', 'FAQ', 'ContactForm', 'Footer', 'WhatsAppFloat'],
    tag:        'Servicios técnicos',
  },
  {
    href:       '/demo/restaurante',
    title:      'Restaurante',
    client:     'El Fogón de Caracas',
    desc:       'Restaurante de cocina venezolana tradicional con reservas y galería.',
    color:      'from-red-800 to-amber-600',
    components: ['Navbar', 'HeroCentered', 'About', 'CardGrid', 'Gallery', 'StatsBar', 'Testimonials', 'CTABanner', 'ContactForm', 'Footer', 'WhatsAppFloat'],
    tag:        'Restaurante & Food',
  },
  {
    href:       '/demo/consultora',
    title:      'Consultora Profesional',
    client:     'Mendoza & Asociados',
    desc:       'Firma de asesoría contable, fiscal y empresarial con planes de precio.',
    color:      'from-slate-700 to-blue-900',
    components: ['Navbar', 'HeroCentered', 'LogoBar', 'CardGrid', 'ProcessSteps', 'PricingCards', 'Testimonials', 'FAQ', 'ContactForm', 'Footer', 'WhatsAppFloat'],
    tag:        'Servicios profesionales',
  },
];
---
<CatalogLayout>

  <!-- Top bar -->
  <header class="sticky top-0 z-50 bg-slate-900/95 backdrop-blur border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14">
      <div class="flex items-center gap-3">
        <span class="font-[JetBrains_Mono,monospace] text-slate-400 text-sm">web-modules</span>
        <span class="text-slate-700">/</span>
        <span class="font-[JetBrains_Mono,monospace] text-slate-200 text-sm">catálogo</span>
      </div>
      <nav class="flex items-center gap-1">
        {demos.map(d => (
          <a
            href={d.href}
            class="text-xs text-slate-400 hover:text-white px-3 py-1.5 rounded-md hover:bg-slate-800 transition-colors"
          >
            {d.title}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <!-- Hero del catálogo -->
  <section class="py-24 sm:py-32 border-b border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-flex items-center gap-2 bg-violet-500/10 border border-violet-500/30 text-violet-300 text-xs font-semibold px-3 py-1 rounded-full mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-violet-400 animate-pulse"></span>
        Sistema modular · Astro 6 + Tailwind v4
      </div>
      <h1 class="text-5xl sm:text-6xl font-bold text-white leading-tight tracking-tight">
        Catálogo de<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-sky-400">Componentes</span>
      </h1>
      <p class="mt-6 text-lg text-slate-400 max-w-2xl leading-relaxed">
        17 módulos tipo "puzzle" intercambiables entre clientes. Solo cambian colores y textos.
        El código de los componentes nunca se modifica.
      </p>
      <div class="mt-8 flex flex-wrap gap-6 text-sm text-slate-500">
        <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> TypeScript strict</span>
        <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> Sin colores hardcodeados</span>
        <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> Mobile-first</span>
        <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> Accesibilidad AA</span>
        <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> Sin JS innecesario</span>
      </div>
    </div>
  </section>

  <!-- Componentes por categoría -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    {components.map(cat => (
      <section>
        <div class={`inline-flex items-center gap-2 border rounded-full px-3 py-1 text-xs font-semibold mb-6 ${cat.color}`}>
          <span class={`w-1.5 h-1.5 rounded-full ${cat.dot}`}></span>
          {cat.category}
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cat.items.map(c => (
            <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 flex flex-col gap-3 hover:border-slate-700 transition-colors">
              <div class="flex items-start justify-between gap-2">
                <span class="text-2xl">{c.icon}</span>
                <code class="font-[JetBrains_Mono,monospace] text-xs text-slate-500 bg-slate-800 px-2 py-0.5 rounded shrink-0">
                  {c.file}
                </code>
              </div>
              <div>
                <h3 class="font-semibold text-white text-sm mb-1">{c.name}</h3>
                <p class="text-slate-400 text-xs leading-relaxed">{c.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

  </main>

  <!-- Demos -->
  <section class="border-t border-slate-800 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="text-3xl font-bold text-white">Demos</h2>
        <p class="mt-2 text-slate-400 text-sm">Los mismos componentes reordenados para 3 tipos de negocio distintos.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {demos.map(demo => (
          <a
            href={demo.href}
            class="group relative flex flex-col bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-slate-600 transition-all hover:-translate-y-1 duration-200"
          >
            <!-- Header degradado -->
            <div class={`h-28 bg-gradient-to-br ${demo.color} flex items-end p-5`}>
              <span class="text-xs font-semibold bg-black/30 text-white/80 px-2 py-0.5 rounded-full backdrop-blur-sm">
                {demo.tag}
              </span>
            </div>

            <div class="p-5 flex flex-col gap-3 flex-1">
              <div>
                <p class="text-xs text-slate-500 font-mono mb-1">{demo.client}</p>
                <h3 class="font-bold text-white text-lg leading-tight">{demo.title}</h3>
                <p class="text-slate-400 text-xs mt-1.5 leading-relaxed">{demo.desc}</p>
              </div>

              <div class="flex flex-wrap gap-1 mt-auto pt-3">
                {demo.components.map(c => (
                  <span class="text-xs text-slate-500 bg-slate-800 px-2 py-0.5 rounded font-mono">{c}</span>
                ))}
              </div>

              <div class="flex items-center gap-1 text-slate-400 group-hover:text-white transition-colors text-sm font-medium pt-1">
                Ver demo
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer del catálogo -->
  <footer class="border-t border-slate-800 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-600 font-mono">web-modules v1.0 · palacios3d.com</p>
      <p class="text-xs text-slate-600">Astro 6 · Tailwind CSS v4 · TypeScript strict</p>
    </div>
  </footer>

</CatalogLayout>
